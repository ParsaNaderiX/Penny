{
  "lob_path": "data/nobitex_data/BTCIRT_orderbook.csv",
  "trades_path": "data/nobitex_data/BTCIRT_trades.csv",
  "device": "cuda",

  "tick_size": 10000.0,
  "trade_window_seconds": 60,
  "rolling_window_days": 3,
  "n_levels": 10,

  "T": 32,
  "S": 8,
  "k": 10,
  "alpha": 0.0005,
  "F": 56,
  "num_classes": 3,
  "regime_dim": 4,

  "train_frac": 0.7,
  "val_frac": 0.15,
  "test_frac": 0.15,

  "T_max": 1000,
  "beta_start": 0.0001,
  "beta_end": 0.02,
  "ddim_steps": 50,

  "batch_size": 64,
  "lr": 0.0002,
  "weight_decay": 0.00001,
  "warmup_steps": 500,
  "grad_clip": 1.0,
  "patience": 10,
  "epochs": 15,
  "lambda_trend": 0.5,

  "counterfactual_sigma": 2.0,
  "eval_gen_batches": 4,

  "checkpoint_path": "checkpoints/penny_best.pt",
  "log_dir": "logs",

  "lstm_hidden": 128,
  "lstm_layers": 2,
  "regime_hidden": 64,
  "emb_dim": 128,
  "cond_dim": 256,
  "unet_base": 128,
  "unet_mid": 256,
  "gn_groups": 8,
  "attn_heads": 4,
  "trend_mlp_hidden": 64,
  "trend_dropout": 0.1
}

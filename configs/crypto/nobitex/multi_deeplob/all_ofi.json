{
  "exchange": "nobitex",
  "symbols": [
    "BTCIRT",
    "USDTIRT"
  ],
  "data_dir": "data/resampled/nobitex",
  "cache_root": "data/cache/nobitex",
  "checkpoint_dir": "checkpoints/nobitex/_all",
  "n_lob_levels": 20,
  "feature_mode": "ofi",
  "T_past": 60,
  "label_k": 10,
  "label_alpha": -1,
  "train_frac": 0.7,
  "val_frac": 0.15,
  "stride": 1,
  "deeplob_conv_filters": 32,
  "deeplob_inception_filters": 64,
  "deeplob_lstm_hidden": 64,
  "deeplob_dropout": 0.1,
  "batch_size": 64,
  "lr": 0.0001,
  "weight_decay": 1e-05,
  "warmup_steps": 500,
  "grad_clip": 1.0,
  "epochs": 80,
  "patience": 15,
  "device": "cuda",
  "seed": 42
}
